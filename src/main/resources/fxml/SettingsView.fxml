<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<TabPane xmlns:fx="http://javafx.com/fxml/1"
         fx:controller="com.medicare.controller.SettingsController"
         tabClosingPolicy="UNAVAILABLE"
         prefWidth="1000" prefHeight="700">

    <!-- ====== Tab 1: 管理员管理 ====== -->
    <Tab text="管理员管理">
        <VBox spacing="10">
            <padding>
                <Insets top="15" right="15" bottom="15" left="15"/>
            </padding>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextField fx:id="txtAdminSearch" promptText="用户名" prefWidth="200"/>
                <Button text="查询" onAction="#handleAdminSearch" styleClass="btn-primary"/>
                <Button text="新增管理员" onAction="#handleAdminNew" styleClass="btn-success"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblAdminCount" text="共 0 条"/>
            </HBox>
            <SplitPane dividerPositions="0.5" VBox.vgrow="ALWAYS">
                <TableView fx:id="tableAdmins">
                    <columns>
                        <TableColumn fx:id="colAdminId" text="ID" prefWidth="60"/>
                        <TableColumn fx:id="colAdminUsername" text="用户名" prefWidth="150"/>
                        <TableColumn fx:id="colAdminRealName" text="姓名" prefWidth="150"/>
                        <TableColumn fx:id="colAdminStatus" text="状态" prefWidth="80"/>
                        <TableColumn fx:id="colAdminCreateTime" text="创建时间" prefWidth="150"/>
                    </columns>
                </TableView>
                <VBox spacing="10" styleClass="form-panel">
                    <padding>
                        <Insets top="10" right="10" bottom="10" left="10"/>
                    </padding>
                    <Label text="管理员信息编辑" styleClass="form-title"/>
                    <GridPane vgap="10" hgap="10">
                        <Label text="用户名*" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <TextField fx:id="txtAdminUsername" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                        <Label text="密码*" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <PasswordField fx:id="txtAdminPassword" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                        <Label text="姓名" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                        <TextField fx:id="txtAdminRealName" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                        <Label text="状态" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                        <ComboBox fx:id="cmbAdminStatus" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
                    </GridPane>
                    <HBox spacing="10" alignment="CENTER_RIGHT">
                        <Label fx:id="lblAdminMessage" text=""/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="保存" onAction="#handleAdminSave" styleClass="btn-primary"/>
                        <Button text="清除" onAction="#handleAdminClear"/>
                        <Button text="删除" onAction="#handleAdminDelete" styleClass="btn-danger"/>
                    </HBox>
                </VBox>
            </SplitPane>
        </VBox>
    </Tab>

    <!-- ====== Tab 2: 修改密码 ====== -->
    <Tab text="修改密码">
        <VBox alignment="CENTER" spacing="15" styleClass="form-panel">
            <padding>
                <Insets top="40" right="40" bottom="40" left="40"/>
            </padding>
            <VBox spacing="20" maxWidth="400" alignment="CENTER">
                <Label text="修改登录密码" styleClass="form-title"/>
                <GridPane vgap="12" hgap="10">
                    <Label text="原密码" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <PasswordField fx:id="txtOldPassword" promptText="请输入原密码" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                    <Label text="新密码" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <PasswordField fx:id="txtNewPassword" promptText="请输入新密码" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                    <Label text="确认新密码" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                    <PasswordField fx:id="txtConfirmPassword" promptText="请再次输入新密码" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                </GridPane>
                <Label fx:id="lblPwdMessage" text=""/>
                <Button text="确认修改" onAction="#handleChangePassword" styleClass="btn-primary" maxWidth="Infinity"/>
            </VBox>
        </VBox>
    </Tab>

</TabPane>
